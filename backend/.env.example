# Copy to backend/.env — the real .env is gitignored. NEVER commit keys
# or place them in any frontend file.

# Model providers (either works; OpenRouter is preferred if both are set;
# with neither, Leviathan runs a mock brain so you can test the loop)
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GEMINI_MODEL=gemini-2.5-flash

# Long-term memory: Supabase pgvector when set, local SQLite otherwise.
# IMPORTANT: use the SESSION POOLER string (Dashboard -> Connect ->
# Session pooler) — the direct db.*.supabase.co host is IPv6-only and
# unreachable from most hosts. URL-encode special chars in the password.
SUPABASE_DB_URL=

# Tool providers — all optional, every tool has a keyless default:
# web_search: Tavily if set, else DuckDuckGo (keyless)
TAVILY_API_KEY=
# generate_image: HF FLUX.1-schnell if set, else Pollinations (keyless)
HF_TOKEN=

# run_code sandbox (requires Docker Desktop; the tool refuses to run
# code anywhere but inside a container)
LEVIATHAN_DOCKER_IMAGE=python:3.11-slim
LEVIATHAN_CODE_TIMEOUT=20

# Optional server-side STT (needs faster-whisper installed)
LEVIATHAN_SERVER_STT=0
WHISPER_MODEL=base

# Where the web client lives — device-link invite URLs point here
WEB_ORIGIN=https://leviathan-web.onrender.com

LEVIATHAN_HOST=0.0.0.0
LEVIATHAN_PORT=8000
